pkgbase = astrobox-ng
	pkgdesc = AstroBox is a leading tool for managing and extending wearable devices
	pkgver = 2.0.0
	pkgrel = 1
	url = https://github.com/AstralSightStudios/AstroBox-NG
	arch = x86_64
	license = AGPL-3.0
	makedepends = curl
	depends = webkit2gtk-4.1
	depends = gtk3
	depends = libx11
	depends = gcc-libs
	depends = glibc
	depends = zlib
	depends = bzip2
	depends = libxcb
	depends = libxkbcommon
	depends = dbus
	depends = libsecret
	depends = libsoup3
	depends = gstreamer
	depends = gst-plugins-base
	depends = libepoxy
	depends = atk
	depends = at-spi2-core
	depends = cairo
	depends = pango
	depends = gdk-pixbuf2
	depends = harfbuzz
	depends = hicolor-icon-theme
	depends = desktop-file-utils
	depends = shared-mime-info
	options = !debug

pkgname = astrobox-ng
